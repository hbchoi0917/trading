# Gmail SMTP credentials for trading alert notifications
# -------------------------------------------------------
# 1. Copy this file to .env (cp .env.example .env)
# 2. Fill in your values below
# 3. .env is blocked by .gitignore — it will NEVER be committed to GitHub
#
# Gmail App Password setup:
#   https://myaccount.google.com/apppasswords
#   (Requires 2FA enabled on your Google account)

GMAIL_SENDER=your_email@gmail.com
GMAIL_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_RECEIVER=your_email@gmail.com
